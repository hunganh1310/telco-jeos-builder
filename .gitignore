# ===========================================================================
# .gitignore — Telco JeOS Builder
# ===========================================================================

# Build output directory (all artifacts)
build/

# Kernel source (large, downloadable)
linux-*/
*.tar.xz
*.tar.gz
*.tar.bz2

# Kernel build artifacts
*.o
*.ko
*.mod
*.mod.c
*.cmd
modules.order
Module.symvers
vmlinux
vmlinuz

# RPM packages (binary)
*.rpm
rpmbuild/

# Kiwi-ng image output (binary)
*.qcow2
*.raw
*.iso
*.vmdk

# Repo metadata (regenerated by createrepo_c)
repodata/

# Logs
*.log

# OS / Editor
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Legacy directories (removed during restructure)
task1-kernel/
task2-kiwi/
task3-bootscript/
task4-testing/
os-definitions/
overlays/
scripts/
