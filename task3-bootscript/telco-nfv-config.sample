#=============================================================================
# /etc/telco-nfv/config
# 
# Override defaults for telco-nfv-init.sh
# Copy this file to /etc/telco-nfv/config inside the image
#=============================================================================

# HugePages (số lượng pages)
HUGEPAGES_2M=1024        # 1024 x 2MB = 2GB
HUGEPAGES_1G=0           # 1GB hugepages (cần boot param hugepagesz=1G)

# Network
NET_MODE="dhcp"          # "dhcp" hoặc "static"
NET_IFACE="eth0"         # Interface chính

# Static IP config (chỉ dùng khi NET_MODE="static")
NET_IP="192.168.1.100/24"
NET_GATEWAY="192.168.1.1"
NET_DNS="8.8.8.8"

# Kernel modules to load
TELCO_MODULES="vfio vfio-pci vhost_net tun tap bonding 8021q bridge"
