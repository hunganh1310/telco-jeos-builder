<?xml version="1.0" encoding="utf-8"?>
<!--
  config.xml — Kiwi-NG image definition for Telco JeOS
  
  This builds a minimal QCOW2 image optimized for NFV/VNF workloads.
  
  Prerequisites:
    - Custom kernel RPM built and available in a local repo
    - Update the telco-kernel-local source path below to match your environment
    
  Build:
    sudo kiwi-ng system build \
      - -description ./image \
      - -target-dir  ./build/image
-->

<image schemaversion="7.4" name="telco-jeos">
    <description type="system">
        <author>Hung Anh</author>
        <contact>etoxanh</contact>
        <specification>
            Telco JeOS Image - Linux 6.6.70-telco-nfv
            Minimal OS for NFV/VNF workloads (DPDK, KVM, VFIO)
        </specification>
    </description>

    <preferences>
        <version>1.0.0</version>
        <packagemanager>zypper</packagemanager>
        <locale>en_US</locale>
        <keytable>us</keytable>
        <timezone>UTC</timezone>
        <rpm-check-signatures>false</rpm-check-signatures>

        <type
            image="oem"
            filesystem="ext4"
            format="qcow2"
            firmware="bios"
            kernelcmdline="console=ttyS0,115200 console=tty0 net.ifnames=0 biosdevname=0 hugepagesz=2M hugepages=512 iommu=pt intel_iommu=on"
        >
            <bootloader name="grub2" console="serial" timeout="3"/>
            <oemconfig>
                <oem-resize>false</oem-resize>
            </oemconfig>
        </type>
    </preferences>

    <!-- ================================================================
         REPOSITORIES
         ================================================================ -->

    <!-- openSUSE Tumbleweed base repository -->
    <repository type="rpm-md" alias="openSUSE-Tumbleweed-Oss" priority="1">
        <source path="https://download.opensuse.org/tumbleweed/repo/oss/"/>
    </repository>

    <!--
        Local repository containing the custom kernel RPM.
        IMPORTANT: Update this path to match your build environment.
        After building the kernel RPM, run:
          createrepo_c /path/to/rpmbuild/RPMS/x86_64/
    -->
    <repository type="rpm-md" alias="telco-kernel-local" priority="0">
        <source path="dir:///REPLACE_WITH_REPO_PATH/"/>
    </repository>

    <!-- ================================================================
         BOOTSTRAP PACKAGES (minimal root filesystem)
         ================================================================ -->
    <packages type="bootstrap">
        <package name="filesystem"/>
        <package name="glibc-locale-base"/>
        <package name="ca-certificates"/>
        <package name="ca-certificates-mozilla"/>
        <package name="openssl"/>
        <package name="coreutils"/>
        <package name="bash"/>
    </packages>

    <!-- ================================================================
         IMAGE PACKAGES
         ================================================================ -->
    <packages type="image">
        <!-- Custom Telco/NFV kernel -->
        <package name="kernel-telco-nfv"/>

        <!-- Base system -->
        <package name="systemd"/>
        <package name="dbus-1"/>
        <package name="udev"/>
        <package name="util-linux"/>
        <package name="grep"/>
        <package name="sed"/>
        <package name="gawk"/>
        <package name="less"/>
        <package name="which"/>
        <package name="procps"/>
        <package name="iputils"/>
        <package name="iproute2"/>
        <package name="shadow"/>
        <package name="pam"/>
        <package name="pam_pwquality"/>
        <package name="gzip"/>
        <package name="tar"/>
        <package name="xz"/>
        <package name="dracut"/>
        <package name="kmod"/>

        <!-- Networking -->
        <package name="wicked"/>
        <package name="openssh"/>
        <package name="openssh-server"/>
        <package name="ethtool"/>
        <package name="bridge-utils"/>

        <!-- Telco/NFV tools -->
        <package name="numactl"/>
        <package name="hwloc"/>
        <package name="tuned"/>

        <!-- Bootloader -->
        <package name="grub2"/>

        <!-- Utilities -->
        <package name="vim"/>
        <package name="curl"/>
        <package name="wget"/>
        <package name="sudo"/>
        <package name="timezone"/>
    </packages>

    <!-- ================================================================
         PACKAGE REMOVAL (busybox conflicts)
         ================================================================ -->
    <packages type="delete">
        <package name="busybox-coreutils"/>
        <package name="busybox-util-linux"/>
        <package name="busybox-gzip"/>
        <package name="busybox-sed"/>
        <package name="busybox-grep"/>
        <package name="busybox-findutils"/>
        <package name="busybox-diffutils"/>
        <package name="busybox-hostname"/>
        <package name="busybox-tar"/>
        <package name="busybox-xz"/>
        <package name="busybox-which"/>
        <package name="busybox-less"/>
        <package name="busybox-gawk"/>
    </packages>

    <!-- ================================================================
         USERS (default password: linux)
         ================================================================ -->
    <users>
        <user
            password="!"
            home="/root"
            name="root"
            groups="root"
        />
        <user
            password="$1$wYJUgpM5$RXMMeRAfUG3J1NbKTrQFG0"
            home="/home/telco"
            name="telco"
            groups="telco,wheel"
            shell="/bin/bash"
        />
    </users>

</image>
